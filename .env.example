PORT=5000
JWT_SECRET=your_jwt_secret_here
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=farmease
REQUIRE_DB=false
OPENWEATHER_API_KEY=your_openweather_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Deployment Variables
# DATABASE_URL is used to connect to remote databases like Supabase. If provided, DB_HOST/PORT/USER/PASSWORD are ignored.
DATABASE_URL=
# DB_SSL can be set to true to force SSL, or false to disable SSL. Default auto-detects based on localhost vs remote.
DB_SSL=
# VITE_API_BASE_URL specifies the production backend API URL for the Vercel frontend.
VITE_API_BASE_URL=

